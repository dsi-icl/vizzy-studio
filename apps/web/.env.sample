# Optional: public base URL used by runtime URL generation and auth host/origin fallbacks.
VITE_BASE_URL=http://localhost:3670

# Optional: enable HTTPS dev certs in Vite (`true`/`false`).
VITE_HTTPS=false

# Required: MongoDB connection string (replica set or mongos topology required).
SERVER_DATABASE_URL=mongodb://user:secret@localhost:27017/vizzy?authSource=admin&replicaSet=rs0

# Required: auth/session signing secret.
SERVER_AUTH_SECRET=change-this-to-a-strong-secret

# Required: encryption key for sensitive config values.
SERVER_CONFIG_ENCRYPTION_KEY=change-this-to-an-other-strong-secret

# Optional: base directory for persisted runtime data (uploads/tmp/assets/controllers).
APP_DATA_DIR=./.data

# Optional: comma-separated auth allowed hosts (hostnames and/or full URLs).
ALLOWED_HOSTS=http://localhost:3670

# Optional: comma-separated trusted origins for auth origin validation.
TRUSTED_ORIGINS=http://localhost:3670

# Optional: enable outbound connectivity check during boot (`true`/`false`).
BOOT_NETWORK_CHECK_ENABLED=true

# Optional: host used for the startup outbound network check.
BOOT_NETWORK_CHECK_HOST=example.com

# Optional: port used for the startup outbound network check.
BOOT_NETWORK_CHECK_PORT=443

# Optional: timeout (ms) for startup outbound network check.
BOOT_NETWORK_CHECK_TIMEOUT_MS=5000

# Optional: per-subject API rate limit (requests per minute) used by server rate limiter.
RATE_LIMIT_PER_MINUTE=60

# Optional: trust forwarded proxy headers for client IP detection (`true`/`false`).
TRUST_FORWARDED_HEADERS=false

# Optional: upload pipeline strictness; when true, unsupported files are rejected hard.
STRICT_BLOCKING=true

# Optional: comma-separated host allowlist for /api/web-screenshot.
WEB_SCREENSHOT_ALLOWLIST=

# Optional: local ffmpeg binary path for media processing jobs.
FFMPEG_PATH=
